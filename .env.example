# ──────────────────────────────────────
# 環境変数テンプレート
# このファイルを .env にコピーして値を入力してください
# .env は絶対にGitHubにpushしないこと！（.gitignoreに追加必須）
# ──────────────────────────────────────

# LINE Messaging API
LINE_CHANNEL_SECRET=ここにLINEチャンネルシークレットを入力
LINE_CHANNEL_ACCESS_TOKEN=ここにLINEチャンネルアクセストークンを入力

# Anthropic Claude API
ANTHROPIC_API_KEY=ここにAnthropicのAPIキーを入力

# 国土交通省 不動産情報ライブラリ API
LIBRARY_API_KEY=ここに不動産情報ライブラリのAPIキーを入力

# MLIT MCPサーバーのパス（通常は変更不要）
MCP_SERVER_PATH=mcp/mlit-geospatial-mcp/src/server.py
